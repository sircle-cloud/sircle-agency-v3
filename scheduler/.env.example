# SIRCLE Scheduler — omgevingsvariabelen.
# Kopieer naar .env.local en vul in. Zonder deze file draait alles in dev-modus
# (in-memory DB + mock-agenda + console-mail) — geen keys nodig.

# ---- Adapterkeuze (composition root, src/config.ts) ----
DB_DRIVER=memory          # memory (default) | prisma
CALENDAR_DRIVER=mock      # mock (default) | nylas
MAIL_DRIVER=console       # console (default) | resend

# ---- Admin-sessies (Fase 2) ----
# HMAC-secret voor de sessie-cookies. ZET een lange random waarde in productie.
SESSION_SECRET=dev-insecure-secret-change-me

# ---- PostgreSQL (DB_DRIVER=prisma) ----
# Gebruik een EU-regio (§6). Draai daarna `npm run prisma:migrate` én de
# handmatige exclusion-constraint uit prisma/migrations/manual/.
DATABASE_URL=postgresql://user:pass@host:5432/sircle_scheduler?schema=public

# ---- Nylas (CALENDAR_DRIVER=nylas + OAuth-koppelflow) ----
# EU-regio (Ierland) conform AVG. Grant-id's ontstaan uit de Nylas hosted-auth
# OAuth-flow (Google/Outlook) en worden per host in CalendarConnection opgeslagen.
NYLAS_API_KEY=            # dient ook als client_secret bij de token-exchange
NYLAS_CLIENT_ID=         # Nylas application-id (nodig voor de OAuth-koppelflow)
NYLAS_API_URI=https://api.eu.nylas.com

# ---- Resend (MAIL_DRIVER=resend) ----
RESEND_API_KEY=
RESEND_FROM=SIRCLE Planner <afspraken@jouwdomein.nl>
