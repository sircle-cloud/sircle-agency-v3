{
  "name": "sircle-agency-v3",
  "private": true,
  "description": "Test suite for sircle.agency — static site tests only, no build tools for the site itself",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:html": "html-validate \"*.html\" \"werk/*.html\"",
    "test:all": "vitest run && html-validate \"*.html\" \"werk/*.html\""
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "glob": "^13.0.6",
    "html-validate": "^9.4.0",
    "jsdom": "^26.0.0",
    "vitest": "^3.1.1"
  }
}
